        "properties": {
          "chartName": {
            "type": "string"
          },
          "releaseName": {
            "type": "string"
          },
          "sha256Digest": {
            "type": [
              "string",
              "null"
            ]
          },
          "urls": {
            "type": [
              "array",
              "null"
