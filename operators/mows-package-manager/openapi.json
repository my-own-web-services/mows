        "properties": {
          "original_template": {
            "type": "string"
          }
        }
      },
      "RemoteFile": {
        "type": "object",
        "required": [
          "urls",
          "sha256Digest"
        ],
        "properties": {
          "sha256Digest": {
            "type": "string"
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Multiple URLs are allowed for redundancy"
          }
        }
      },
      "RemoteFilesSpec": {
        "type": "object",
        "required": [
          "files"
        ],
        "properties": {
          "files": {
