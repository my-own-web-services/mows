              "helm"
            ],
            "properties": {
              "helm": {
                "$ref": "#/components/schemas/HelmRepoSpec"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "files"
            ],
            "properties": {
              "files": {
                "$ref": "#/components/schemas/FilesSpec"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "remoteFiles"
            ],
            "properties": {
              "remoteFiles": {
                "$ref": "#/components/schemas/RemoteFilesSpec"
              }
            }
          }
        ]
      },
      "MethodSpecificRenderedDocumentDebug": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "Helm"
            ],
            "properties": {
              "Helm": {
                "$ref": "#/components/schemas/MethodSpecificRenderedDocumentDebugHelm"
              }
            }
          }
        ]
      },
