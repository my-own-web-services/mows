          "secrets": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "target": {
            "$ref": "#/components/schemas/RenderRepositoriesTarget"
          },
          "uri": {
            "type": "string"
          }
        }
      },
      "RenderRepositoriesReqBody": {
        "type": "object",
        "required": [
          "repositories"
        ],
        "properties": {
          "repositories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RenderRepositoriesRepository"
            }
          }
        }
      },
      "RenderRepositoriesResBody": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/RenderedDocument"
              }
            }
          }
        }
      },
      "RenderRepositoriesTarget": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "RenderOnly"
            ],
            "properties": {
              "RenderOnly": {
                "$ref": "#/components/schemas/RenderRepositoriesTargetRenderOnly"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "KubectlApply"
            ],
            "properties": {
              "KubectlApply": {
                "$ref": "#/components/schemas/RenderRepositoriesTargetKubectlApply"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "Git"
            ],
            "properties": {
              "Git": {
                "$ref": "#/components/schemas/RenderRepositoriesTargetGit"
              }
            }
          }
        ]
      },
      "RenderRepositoriesTargetGit": {
        "type": "object"
      },
      "RenderRepositoriesTargetKubectlApply": {
        "type": "object",
        "required": [
          "kubeconfig"
        ],
        "properties": {
          "kubeconfig": {
            "type": "string"
          }
        }
      },
      "RenderRepositoriesTargetRenderOnly": {
        "type": "object"
      },
      "RenderedDocument": {
        "type": "object",
        "required": [
          "resource",
          "source_name",
          "source_type",
          "debug"
        ],
        "properties": {
          "debug": {
            "$ref": "#/components/schemas/RenderedDocumentDebug"
          },
          "resource": {},
          "source_name": {
            "type": "string"
          },
          "source_type": {
            "$ref": "#/components/schemas/ManifestSource"
          }
        }
      },
      "RenderedDocumentDebug": {
        "type": "object",
        "properties": {
          "method_specific": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/MethodSpecificRenderedDocumentDebug"
              }
            ]
          },
          "resource_source_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "resource_string_before_parse": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
