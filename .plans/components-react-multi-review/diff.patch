                selectionShowsNumbers: string;
                throwsOutsideSteps: string;
                endAlignmentSide: string;
                endAlignmentCenter: string;
                loadingIndeterminate: string;
                loadingDeterminate: string;
            };
        };
        rtl: DocSectionBody;
        apiReference: { title: string; intro: string };
    };
}

