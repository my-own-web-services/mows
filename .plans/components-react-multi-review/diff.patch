+    const domNode = useStore((s) => s.domNode);
+
+    React.useEffect(() => {
+        if (nodesInitialized || !domNode || getNodes.length === 0) return;
+        const ids: string[] = [];
+        const measurements = new Map<string, { width: number; height: number }>();
+        for (const n of getNodes) {
+            const el = domNode.querySelector(
+                `.react-flow__node[data-id="${CSS.escape(n.id)}"]`
+            ) as HTMLElement | null;
+            if (!el) continue;
+            const w = el.offsetWidth;
+            const h = el.offsetHeight;
+            if (w === 0 || h === 0) continue;
+            measurements.set(n.id, { width: w, height: h });
+            ids.push(n.id);
+        }
+        if (ids.length === 0) return;
+        setNodes(
+            getNodes.map((n) => {
+                const m = measurements.get(n.id);
+                if (!m) return n;
+                return { ...n, measured: m, width: m.width, height: m.height };
+            })
+        );
+        updateNodeInternals(ids);
+    }, [nodesInitialized, getNodes, domNode, setNodes, updateNodeInternals]);
+
+    return null;
+};
