{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "lib": ["ES2022", "DOM"],
        "types": ["vite/client"]
    },
    "include": ["src"]
}
